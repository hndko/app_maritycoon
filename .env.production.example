NODE_ENV=production

# Public URLs. Use the final HTTPS domain.
PUBLIC_APP_URL=https://maritycoon.example.com
PUBLIC_API_URL=https://maritycoon.example.com
PUBLIC_SOCKET_URL=https://maritycoon.example.com
CORS_ORIGIN=https://maritycoon.example.com

# PostgreSQL. Replace all secrets before deploy.
POSTGRES_DB=maritycoon
POSTGRES_USER=maritycoon_app
POSTGRES_PASSWORD=replace-with-strong-postgres-password
DATABASE_URL=postgresql://maritycoon_app:replace-with-strong-postgres-password@postgres:5432/maritycoon

# Redis. The password must also match docker-compose.production.yml interpolation.
REDIS_PASSWORD=replace-with-strong-redis-password
REDIS_URL=redis://:replace-with-strong-redis-password@redis:6379

# Backend hardening.
SESSION_TOKEN_SECRET=replace-with-at-least-32-random-characters
TRUST_PROXY=true
LOG_FORMAT=json

# Optional operational settings.
BACKUP_DIR=./backups
