NODE_ENV=development
FRONTEND_PORT=3000
BACKEND_PORT=4000
DATABASE_URL=postgresql://maritycoon:maritycoon@localhost:5432/maritycoon
REDIS_URL=redis://localhost:6379
SESSION_TOKEN_SECRET=dev-session-secret
CORS_ORIGIN=http://localhost:3000
PUBLIC_APP_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:4000
PUBLIC_SOCKET_URL=http://localhost:4000
TRUST_PROXY=false
LOG_FORMAT=pretty

# Production-only Docker Compose values. Replace every value before deploy.
POSTGRES_DB=maritycoon
POSTGRES_USER=maritycoon
POSTGRES_PASSWORD=change-this-postgres-password
REDIS_PASSWORD=change-this-redis-password
